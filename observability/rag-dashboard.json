{
  "title": "RAG Platform Dashboard",
  "uid": "rag-platform",
  "panels": [
    {
      "title": "Query Latency (p95)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Queries per Second",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(rag_query_total[5m])",
          "legendFormat": "qps"
        }
      ]
    },
    {
      "title": "Guardrail Violations",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(rag_guardrail_violations_total[5m])",
          "legendFormat": "{{check_type}}"
        }
      ]
    },
    {
      "title": "Token Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(rag_tokens_input_total[5m])",
          "legendFormat": "input"
        },
        {
          "expr": "rate(rag_tokens_output_total[5m])",
          "legendFormat": "output"
        }
      ]
    },
    {
      "title": "Retrieval Recall@5",
      "type": "stat",
      "targets": [
        {
          "expr": "rag_retrieval_recall_at_5"
        }
      ]
    },
    {
      "title": "Component Health",
      "type": "table",
      "targets": [
        {
          "expr": "up"
        }
      ]
    }
  ]
}
