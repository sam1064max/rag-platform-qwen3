# ──────────────────────────────────────────────
# RAG Platform Environment Configuration
# ──────────────────────────────────────────────

## General
RAG_ENV=development
RAG_LOG_LEVEL=debug

## Qdrant
QDRANT_API_KEY=

## MinIO
MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=ragadmin123

## OpenBao
OPENBAO_TOKEN=

## Langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse123
LANGFUSE_DB_NAME=langfuse
LANGFUSE_SECRET=langfuse-secret-change-me
LANGFUSE_SALT=langfuse-salt-change-me

## Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

## vLLM
HF_TOKEN=
VLLM_API_KEY=not-needed

## LLM Providers (for API/OpenRouter mode)
# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

## Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OTEL_ENDPOINT=http://otel-collector:4317
